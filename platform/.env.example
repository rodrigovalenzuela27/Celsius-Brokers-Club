# --- Supabase (local: los imprime `pnpm db:start`) ---
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Solo server-side (scripts, workers). Bypassa RLS: tratar como secreto.
SUPABASE_SERVICE_ROLE_KEY=

